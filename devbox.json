{
  "$schema":  "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "shellcheck@latest",
    "vagrant@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to Airgap-Bundler!' > /dev/null"
    ],
    "scripts": {
      "build": [
        "./build-bundle.sh"
      ],
      "lint": [
        "shellcheck build-bundle.sh install.sh update_dns.sh"
      ],
      "vm:up": [
        "vagrant up"
      ],
      "vm:rsync": [
        "vagrant rsync"
      ],
      "vm:ssh": [
        "vagrant ssh"
      ],
      "vm:halt": [
        "vagrant halt"
      ],
      "vm:destroy": [
        "vagrant destroy -f"
      ],
      "vm:status": [
        "vagrant status"
      ]
    }
  }
}